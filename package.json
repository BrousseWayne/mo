{
  "name": "mo",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @mo/database generate",
    "db:migrate": "pnpm --filter @mo/database migrate",
    "db:push": "pnpm --filter @mo/database push",
    "db:seed": "pnpm --filter @mo/database seed",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "playground": "tsx scripts/playground.ts"
  },
  "devDependencies": {
    "dotenv": "^16",
    "tsx": "^4",
    "turbo": "^2",
    "typescript": "^5.7"
  }
}
