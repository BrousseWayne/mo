DATABASE_URL=postgresql://mo:mo@127.0.0.1:5432/mo
ANTHROPIC_API_KEY=sk-ant-...
USDA_FDC_API_KEY=your-usda-fdc-api-key
REDIS_URL=redis://127.0.0.1:6379
PORT=3100

# LLM adapter mode: headless (claude -p via Claude Code CLI) or api (@anthropic-ai/sdk)
LLM_MODE=headless

# Personal OAuth token from `claude setup-token` (optional: the headless adapter
# falls back to the CLI's stored login when unset). Subscription auth is for
# PERSONAL use only — never embed this token in anything serving third parties.
# If MO ever goes multi-client, switch to LLM_MODE=api with a real API key.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
